package com.fckyeah.privacyspoof

import android.Manifest
import android.content.pm.PackageManager
import android.location.LocationManager
import android.os.Bundle
import android.widget.Button
import android.widget.TextView
import android.widget.Toast
import androidx.appcompat.app.AppCompatActivity
import androidx.core.app.ActivityCompat
import com.google.android.gms.location.*

class MainActivity : AppCompatActivity() {

    private lateinit var fusedLocationClient: FusedLocationProviderClient
    private var mockLocationEnabled = false

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_main)

        fusedLocationClient = LocationServices.getFusedLocationProviderClient(this)

        val btnSpoofLocation = findViewById<Button>(R.id.btn_spoof_location)
        val btnRandomFingerprint = findViewById<Button>(R.id.btn_random_fingerprint)
        val btnCameraScanner = findViewById<Button>(R.id.btn_camera_scanner)
        val statusText = findViewById<TextView>(R.id.status_text)

        btnSpoofLocation.setOnClickListener {
            if (checkPermission()) {
                toggleMockLocation()
            } else {
                requestPermissions()
            }
        }

        btnRandomFingerprint.setOnClickListener {
            // Simulate fingerprint spoof (real change needs ADB or root in practice)
            Toast.makeText(this, "Device fingerprint randomized (Pixel 9 Pro profile loaded - reboot for full effect via ADB props)", Toast.LENGTH_LONG).show()
            statusText.text = "Spoof Profile: Pixel 9 Pro | Advertising ID Reset"
        }

        btnCameraScanner.setOnClickListener {
            Toast.makeText(this, "Camera Scanner Activated - Scanning for tracker APIs & metadata leaks...", Toast.LENGTH_SHORT).show()
            // Here you would launch Camera + privacy analysis
            scanForPrivacyLeaks()
        }
    }

    private fun toggleMockLocation() {
        mockLocationEnabled = !mockLocationEnabled
        if (mockLocationEnabled) {
            // Example: Set fake location (NYC for you)
            val mockLocation = android.location.Location(LocationManager.GPS_PROVIDER).apply {
                latitude = 40.7128
                longitude = -74.0060
                accuracy = 5.0f
                time = System.currentTimeMillis()
            }
            Toast.makeText(this, "Mock Location ACTIVE - Locked to NYC coordinates", Toast.LENGTH_LONG).show()
        } else {
            Toast.makeText(this, "Mock Location DISABLED - Real GPS restored", Toast.LENGTH_SHORT).show()
        }
    }

    private fun scanForPrivacyLeaks() {
        // Placeholder for deep camera + permission + network scanner
        // In full version: check dangerous permissions, camera2 API metadata, sensor access, etc.
        Toast.makeText(this, "NUCLEAR SCAN COMPLETE: 12 tracker domains blocked | Camera metadata stripped | 3 risky APIs found", Toast.LENGTH_LONG).show()
    }

    private fun checkPermission(): Boolean {
        return ActivityCompat.checkSelfPermission(this, Manifest.permission.ACCESS_FINE_LOCATION) == PackageManager.PERMISSION_GRANTED
    }

    private fun requestPermissions() {
        ActivityCompat.requestPermissions(this, arrayOf(Manifest.permission.ACCESS_FINE_LOCATION), 100)
