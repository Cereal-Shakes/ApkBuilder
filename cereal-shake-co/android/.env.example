# ─── App ───
APP_SECRET=your-super-secret-jwt-key-here
NODE_ENV=development
PORT=3000

# ─── Database ───
DATABASE_URL=mysql://user:password@localhost:3306/cerealicious

# ─── Kimi OAuth ───
KIMI_CLIENT_ID=your-kimi-client-id
KIMI_CLIENT_SECRET=your-kimi-client-secret
KIMI_REDIRECT_URI=http://localhost:3000/auth/callback

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_live_...          # or sk_test_... for development
STRIPE_WEBHOOK_SECRET=whsec_...        # from Stripe dashboard > Webhooks
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_... # or pk_test_...

# ─── Google Maps (for delivery tracking) ───
VITE_GOOGLE_MAPS_KEY=your-google-maps-embed-api-key

# ─── Driver App Auth ───
DRIVER_API_TOKEN=a-secure-random-token-for-driver-app

# ─── Email (optional, for order confirmations) ───
SENDGRID_API_KEY=SG...
FROM_EMAIL=orders@cerealicious.com
